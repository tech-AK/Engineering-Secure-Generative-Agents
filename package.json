{
  "name": "sega",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "scripts": {
    "dev": "concurrently -P \"webpack --config webpack.config.js --watch\" \"nodemon --watch src src/server/main.ts -- {@}\" --",
    "build:client": "webpack --config webpack.config.js --mode=production --stats-error-details",
    "build:server": "tsc -p src/server/tsconfig.json",
    "build": "npm run build:client && npm run build:server",
    "start": "pm2-runtime build/server/main.js",
    "deploy": "(docker rm -f sega || true) && docker build -t sega . && docker run --name sega --rm --detach -p 8080:8080 sega",
    "hash": "node -e \"console.log(require('bcrypt').hashSync(process.argv[1], 10))\""
  },
  "author": "",
  "license": "GPL-3.0",
