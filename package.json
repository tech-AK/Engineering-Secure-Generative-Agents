    "@types/express-http-proxy": "^1.6.6",
    "@types/node": "^20.14.5",
    "@types/pdf-parse": "^1.1.4",
    "@types/uuid": "^9.0.8",
    "@vue/compiler-sfc": "^3.4.27",
